{
  "name": "@react-geoportail/sdk",
  "version": "0.1.0",
  "description": "React SDK for the Geoportail Luxembourg v3 API",
  "type": "module",
  "main": "./dist/react-geoportail.umd.cjs",
  "module": "./dist/react-geoportail.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/react-geoportail.js",
      "require": "./dist/react-geoportail.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0"
  },
  "keywords": ["geoportail", "luxembourg", "map", "react", "openlayers", "geocode"],
  "license": "MIT"
}
